
WITH UniqueLogins AS (
    SELECT DISTINCT user_id, login_date 
    FROM user_logins
),
GroupedLogins AS (
    SELECT 
        user_id,
        login_date,
        login_date - CAST(ROW_NUMBER() OVER (PARTITION BY user_id ORDER BY login_date) AS INT) AS date_group
    FROM UniqueLogins
)
SELECT DISTINCT user_id
FROM GroupedLogins
GROUP BY user_id, date_group
HAVING COUNT(*) >= 3;
